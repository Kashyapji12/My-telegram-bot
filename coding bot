# Initialize git
git init

# Add all files
git add .

# First commit
git commit -m "🔥 CodeFlow - Sigma Bot Ready!"

# Rename branch to main (important!)
git branch -M main

# Add remote (replace USERNAME with your GitHub username)
git remote add origin https://github.com/Kashyapji12/CodeFlow.git

# Push to GitHub
git push -u origin main